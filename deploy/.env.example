# Copy to /home/guibson/projetos/blog/.env on the VPS and fill in real values.
# Sourced by the deploy step before `docker stack deploy` (swarm ignores env_file).
# Never commit the real .env.

# Image tag to deploy. The CD pipeline overrides this with the released version
# (e.g. v2026.05.31-12). Leave as latest for manual deploys.
IMAGE_TAG=latest

# Rails secret — required for the app to boot in production.
# Generate once with:  docker run --rm ghcr.io/guibsonmoura/blog:latest ./bin/rails secret
SECRET_KEY_BASE=

# Postgres password — used by BOTH the db service (role: workspace) and the app.
WORKSPACE_DATABASE_PASSWORD=change-me

# JWT signing for admin auth.
JWT_SECRET=change-me

# Seed admin user (created by db:prepare on first boot; password min 12 chars).
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=change-me-min-12-chars

# Active Storage backend. "minio" uses the in-stack S3-compatible MinIO service
# (the default in compose.yml); "local" stores uploads on the `storage` volume.
ACTIVE_STORAGE_SERVICE=minio

# MinIO (S3-compatible) — used when ACTIVE_STORAGE_SERVICE=minio.
# ACCESS/SECRET double as the MinIO root credentials; generate strong values
# (e.g. openssl rand -hex 16 / -hex 32). Endpoint is the in-stack service name.
MINIO_ACCESS_KEY=change-me
MINIO_SECRET_KEY=change-me
MINIO_REGION=us-east-1
MINIO_BUCKET=blog-production

# Log level
RAILS_LOG_LEVEL=info

# --- Reader OAuth (public sign-in) ---
# In production these are normally supplied by the CD pipeline from GitHub Actions
# secrets (GOOGLE_CLIENT_ID, GOOGLE_CLIENT_SECRET, TWITTER_CLIENT_ID, TWITTER_CLIENT_SECRET)
# and exported into the deploy shell — you do NOT need to set them here for a CD deploy.
# Set them below only for a manual `docker stack deploy` on the server. A blank/unset
# value keeps that provider disabled (its button is hidden — see config/initializers/omniauth.rb).
# Register the production redirect URIs in each provider console:
#   Google: https://<prod-domain>/auth/google_oauth2/callback
#   X:      https://<prod-domain>/auth/twitter/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
TWITTER_CLIENT_ID=
TWITTER_CLIENT_SECRET=
