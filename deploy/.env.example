# Copy to /opt/blog/.env on the server and fill in real values.
# Never commit the real .env.

# Rails — required for the production image to boot (from config/master.key)
RAILS_MASTER_KEY=

# Database (the `db` service in compose.yml uses these)
POSTGRES_USER=blog
POSTGRES_PASSWORD=change-me
POSTGRES_DB=blog_production
# App connects to the db service over the compose network:
DATABASE_URL=postgres://blog:change-me@db:5432/blog_production

# JWT signing for admin auth (falls back to secret_key_base if unset)
JWT_SECRET=change-me

# Object storage (MinIO / S3). Use local if not serving uploads yet.
ACTIVE_STORAGE_SERVICE=minio
MINIO_ENDPOINT=http://minio:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=change-me
MINIO_REGION=us-east-1
MINIO_BUCKET=blog-production

# Optional — auto-translation service URL (if you run the translator container)
# TRANSLATION_SERVICE_URL=http://translator:8000
