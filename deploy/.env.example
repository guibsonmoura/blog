# Copy to /home/guibson/projetos/blog/.env on the VPS and fill in real values.
# Sourced by the deploy step before `docker stack deploy` (swarm ignores env_file).
# Never commit the real .env.

# Image tag to deploy. The CD pipeline overrides this with the released version
# (e.g. v2026.05.31-12). Leave as latest for manual deploys.
IMAGE_TAG=latest

# Rails secret — required for the app to boot in production.
# Generate once with:  docker run --rm ghcr.io/guibsonmoura/blog:latest ./bin/rails secret
SECRET_KEY_BASE=

# Postgres password — used by BOTH the db service (role: workspace) and the app.
WORKSPACE_DATABASE_PASSWORD=change-me

# JWT signing for admin auth.
JWT_SECRET=change-me

# Seed admin user (created by db:prepare on first boot; password min 12 chars).
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=change-me-min-12-chars

# Active Storage: "local" stores uploads on the mounted `storage` volume (no MinIO needed).
# Switch to "minio" + add MINIO_* vars if you use S3-compatible storage.
ACTIVE_STORAGE_SERVICE=local

# Log level
RAILS_LOG_LEVEL=info
