<?xml version="1.0" encoding="UTF-8"?>
<rss version="2.0" xmlns:atom="http://www.w3.org/2005/Atom">
  <channel>
    <title>Guibson Moura Blog</title>
    <link><%= root_url %></link>
    <description>Thoughts about software, architecture and technology</description>
    <language><%= I18n.locale %></language>
    <atom:link href="<%= feed_url(format: :xml) %>" rel="self" type="application/rss+xml"/>
    <% @posts.each do |post| %>
      <item>
        <title><%= post.localized_title %></title>
        <link><%= post_url(post) %></link>
        <guid isPermaLink="true"><%= post_url(post) %></guid>
        <description><%= post.localized_excerpt %></description>
        <pubDate><%= post.published_at.rfc2822 %></pubDate>
      </item>
    <% end %>
  </channel>
</rss>
