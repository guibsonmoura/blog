<% page_title "Sobre" %>

<div class="mx-auto max-w-2xl">
  <header class="mb-10">
    <h1 class="text-3xl font-semibold text-neutral-950 dark:text-neutral-50">Guibson Moura</h1>
    <p class="mt-2 text-neutral-500 dark:text-neutral-400">Software engineer · Brazil</p>
  </header>

  <div class="prose-section space-y-6 leading-[1.8] text-neutral-700 dark:text-neutral-300" style="font-size:18px;">
    <p>
      Engenheiro de software apaixonado por arquitetura de sistemas, performance e boas práticas de desenvolvimento.
      Escrevo sobre Ruby on Rails, Python, e tudo que aprendo no dia a dia construindo software.
    </p>

    <p>
      Este blog é um espaço para registrar descobertas, tutoriais e reflexões sobre tecnologia —
      escrito em português, com versão em inglês gerada automaticamente.
    </p>
  </div>

  <section class="mt-12">
    <h2 class="text-sm font-semibold uppercase tracking-widest text-neutral-500 dark:text-neutral-400">Tecnologias</h2>
    <div class="mt-4 flex flex-wrap gap-2">
      <% %w[Ruby Rails Python FastAPI PostgreSQL Docker Linux Git].each do |tech| %>
        <span class="rounded-full border border-neutral-200 px-3 py-1 text-sm text-neutral-600 dark:border-neutral-700 dark:text-neutral-300">
          <%= tech %>
        </span>
      <% end %>
    </div>
  </section>

  <section class="mt-12">
    <h2 class="text-sm font-semibold uppercase tracking-widest text-neutral-500 dark:text-neutral-400">Contato</h2>
    <div class="mt-4 flex flex-col gap-2 text-sm">
      <a href="https://github.com/guibsonmoura" target="_blank" rel="noopener noreferrer"
         class="flex items-center gap-2 text-neutral-600 hover:text-blue-700 dark:text-neutral-400 dark:hover:text-blue-300">
        <svg class="h-4 w-4" viewBox="0 0 24 24" fill="currentColor">
          <path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0 0 24 12c0-6.63-5.37-12-12-12z"/>
        </svg>
        github.com/guibsonmoura
      </a>
    </div>
  </section>
</div>
