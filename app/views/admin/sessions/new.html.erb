<% page_title "Admin sign in" %>

<section class="mx-auto w-full max-w-sm">
  <h1 class="text-3xl font-semibold text-neutral-950 dark:text-neutral-50">Admin sign in</h1>

  <%= form_with url: superadmin_login_path, class: "mt-8 space-y-5" do |form| %>
    <div>
      <%= form.label :email, class: "block text-sm font-medium text-neutral-700 dark:text-neutral-300" %>
      <%= form.email_field :email,
                           required: true,
                           autocomplete: "email",
                           class: "mt-2 w-full rounded-md border border-neutral-300 bg-white px-3 py-2 text-neutral-950 shadow-sm focus:border-blue-600 focus:outline-none dark:border-neutral-700 dark:bg-neutral-900 dark:text-neutral-50" %>
    </div>

    <div>
      <%= form.label :password, class: "block text-sm font-medium text-neutral-700 dark:text-neutral-300" %>
      <%= form.password_field :password,
                              required: true,
                              autocomplete: "current-password",
                              class: "mt-2 w-full rounded-md border border-neutral-300 bg-white px-3 py-2 text-neutral-950 shadow-sm focus:border-blue-600 focus:outline-none dark:border-neutral-700 dark:bg-neutral-900 dark:text-neutral-50" %>
    </div>

    <%= form.submit "Sign in",
                    class: "w-full rounded-md bg-neutral-950 px-4 py-2.5 text-sm font-medium text-white hover:bg-blue-700 dark:bg-neutral-100 dark:text-neutral-950 dark:hover:bg-blue-200" %>
  <% end %>
</section>
