<%# Renders one comment. Locals: comment, allow_reply (top-level only). %>
<% author_name = comment.reader&.name.presence || comment.author_name %>
<% avatar_url = comment.reader&.avatar_url %>
<% like_count = comment.comment_likes.size %>
<% liked = reader_signed_in? ? comment.comment_likes.any? { |l| l.reader_id == current_reader.id } :
                               comment.comment_likes.any? { |l| l.reader_id.nil? && l.session_id == reader_id } %>

<div id="comment-<%= comment.id %>" class="py-4">
  <div class="flex items-center gap-3">
    <% if avatar_url.present? %>
      <%= image_tag avatar_url, alt: "", loading: "lazy", referrerpolicy: "no-referrer",
                    class: "h-6 w-6 shrink-0 rounded-full object-cover" %>
    <% end %>
    <span class="text-sm font-medium text-neutral-950 dark:text-neutral-50"><%= h(author_name) %></span>
    <span class="text-xs text-neutral-400 dark:text-neutral-500"><%= time_ago_in_words(comment.created_at) %> ago</span>
  </div>

  <p class="mt-2 leading-7 text-neutral-700 dark:text-neutral-300 whitespace-pre-wrap break-words"><%= h(comment.body) %></p>

  <div class="mt-2 flex items-center gap-4">
    <%# Like is open to everyone (anonymous-friendly). %>
    <% like_active = liked ? "text-blue-700 dark:text-blue-300" : "text-neutral-500 hover:text-neutral-800 dark:text-neutral-400 dark:hover:text-neutral-200" %>
    <%= button_to comment_like_path(comment),
                  class: "inline-flex items-center gap-1.5 text-sm #{like_active}",
                  aria: { label: t("comments.like") } do %>
      <span aria-hidden="true">👍</span>
      <span class="tabular-nums"><%= like_count %></span>
    <% end %>

    <% if allow_reply %>
      <details class="group">
        <summary class="cursor-pointer list-none text-sm text-neutral-500 hover:text-neutral-800 dark:text-neutral-400 dark:hover:text-neutral-200">
          <%= t("comments.reply") %>
        </summary>
        <div class="mt-3">
          <% if reader_signed_in? %>
            <%= form_with url: post_comments_path(comment.post), class: "space-y-3" do |f| %>
              <%= hidden_field_tag "comment[parent_id]", comment.id %>
              <%= f.text_area :body,
                              required: true,
                              rows: 3,
                              placeholder: t("comments.reply_placeholder"),
                              class: "w-full rounded-md border border-neutral-300 bg-white px-3 py-2 text-sm text-neutral-950 shadow-sm focus:border-blue-600 focus:outline-none dark:border-neutral-700 dark:bg-neutral-900 dark:text-neutral-50" %>
              <%= f.submit t("comments.reply"),
                           class: "rounded-md bg-neutral-950 px-3 py-1.5 text-sm font-medium text-white hover:bg-blue-700 dark:bg-neutral-100 dark:text-neutral-950 dark:hover:bg-blue-200" %>
            <% end %>
          <% else %>
            <p class="text-sm text-neutral-500 dark:text-neutral-400"><%= t("auth.sign_in_to_comment") %></p>
          <% end %>
        </div>
      </details>
    <% end %>
  </div>
</div>
