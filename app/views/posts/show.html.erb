<% page_title @post.localized_title %>
<% toc = @post.toc_items %>

<div class="mx-auto max-w-6xl px-5">
  <div class="grid grid-cols-1 gap-12 lg:grid-cols-[1fr_220px]">

    <article class="min-w-0">
      <header>
        <p class="text-sm text-neutral-500 dark:text-neutral-400">
          <%= display_date(@post.published_at) %>
        </p>

        <h1 class="reading-title mt-4 text-center text-4xl font-semibold leading-tight">
          <%= @post.localized_title %>
        </h1>

        <p class="reading-excerpt mt-6 text-justify">
          <%= @post.localized_excerpt %>
        </p>
      </header>

      <div class="markdown mt-12">
        <%= @post.localized_body %>
      </div>
    </article>

    <% if toc.any? %>
      <aside class="hidden lg:block">
        <div class="sticky top-8">
          <p class="mb-3 text-xs font-semibold uppercase tracking-widest text-neutral-500 dark:text-neutral-400">Contents</p>
          <nav class="space-y-1">
            <% toc.each do |item| %>
              <a href="#<%= item[:anchor] %>"
                 data-turbo="false"
                 class="block text-left leading-snug text-neutral-600 hover:text-blue-700 dark:text-neutral-400 dark:hover:text-blue-300 <%= item[:level] == 2 ? 'text-sm font-medium' : 'pl-3 text-xs' %>">
                <%= item[:text] %>
              </a>
            <% end %>
          </nav>
        </div>
      </aside>
    <% end %>

  </div>
</div>

<div class="mx-auto mt-16 max-w-3xl space-y-12 border-t border-neutral-200 pt-12 dark:border-neutral-800 px-5">
  <%= render "reactions", post: @post %>
  <%= render "comments", post: @post %>
</div>
