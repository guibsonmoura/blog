<% page_title @post.title %>

<article class="mx-auto max-w-3xl">
  <header>
    <p class="text-sm text-neutral-500 dark:text-neutral-400">
      <%= display_date(@post.published_at) %>
    </p>

    <h1 class="mt-4 text-4xl font-semibold leading-tight text-neutral-950 dark:text-neutral-50">
      <%= @post.title %>
    </h1>

    <p class="mt-6 text-lg leading-8 text-neutral-700 dark:text-neutral-300">
      <%= @post.excerpt %>
    </p>
  </header>

  <div class="markdown mt-12">
    <%= @post.rendered_body %>
  </div>
</article>

<div class="mx-auto mt-16 max-w-3xl space-y-12 border-t border-neutral-200 pt-12 dark:border-neutral-800">
  <%= render "reactions", post: @post %>
  <%= render "comments", post: @post %>
</div>
