<article class="border-b border-neutral-200 py-10 first:pt-0 last:border-b-0 dark:border-neutral-800">
  <p class="text-sm text-neutral-500 dark:text-neutral-400">
    <%= display_date(post.published_at) %>
  </p>

  <h2 class="mt-3 text-2xl font-semibold leading-tight text-neutral-950 dark:text-neutral-50">
    <%= link_to post.title, post_path(post), class: "hover:text-blue-700 dark:hover:text-blue-300" %>
  </h2>

  <p class="mt-4 leading-7 text-neutral-700 dark:text-neutral-300">
    <%= post.excerpt %>
  </p>

  <% reaction_count = post.reactions.size; comment_count = post.comments.size %>
  <% if reaction_count > 0 || comment_count > 0 %>
    <p class="mt-3 text-xs text-neutral-400 dark:text-neutral-500">
      <%= t("posts.show.activity", reactions: reaction_count, comments: comment_count) %>
    </p>
  <% end %>
</article>
