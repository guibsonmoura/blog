<article class="grid gap-6 border-b border-neutral-200 py-10 first:pt-0 last:border-b-0 dark:border-neutral-800 md:grid-cols-[180px_1fr]">
  <% if post.cover_image.attached? %>
    <%= image_tag post.cover_image,
                  class: "aspect-[4/3] w-full rounded-md object-cover",
                  alt: "" %>
  <% else %>
    <div class="aspect-[4/3] rounded-md border border-neutral-200 bg-neutral-100 dark:border-neutral-800 dark:bg-neutral-900"></div>
  <% end %>

  <div>
    <p class="text-sm text-neutral-500 dark:text-neutral-400">
      <%= display_date(post.published_at) %> by <%= post.user.name %>
    </p>

    <h2 class="mt-3 text-2xl font-semibold leading-tight text-neutral-950 dark:text-neutral-50">
      <%= link_to post.title, post_path(post), class: "hover:text-blue-700 dark:hover:text-blue-300" %>
    </h2>

    <p class="mt-4 leading-7 text-neutral-700 dark:text-neutral-300">
      <%= post.excerpt %>
    </p>
  </div>
</article>
