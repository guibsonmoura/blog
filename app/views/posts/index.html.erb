<% page_title "Guibson Moura Blog" %>

<div class="grid grid-cols-1 gap-16 lg:grid-cols-[1fr_240px]">

  <%# ─── Main feed ─── %>
  <div>

    <%# Hero %>
    <div class="mb-14 border-b border-neutral-200 pb-10 dark:border-neutral-800">
      <h1 class="text-2xl font-semibold tracking-tight text-neutral-950 sm:text-3xl dark:text-neutral-50">
        Guibson Moura
      </h1>
      <p class="mt-2 text-base leading-relaxed text-neutral-500 dark:text-neutral-400">
        <%= t("posts.index.tagline") %>
      </p>
    </div>

    <%# Archive grouped by year → month %>
    <% if @archive.any? %>
      <% @archive.sort.reverse_each do |year, months| %>
        <section class="mb-14">

          <%# Year label %>
          <div class="mb-8 flex items-center gap-4">
            <span class="text-xs font-semibold uppercase tracking-[0.18em] text-neutral-400 dark:text-neutral-500"><%= year %></span>
            <span class="flex-1 border-t border-neutral-200 dark:border-neutral-800"></span>
          </div>

          <% months.sort.reverse_each do |month_num, posts| %>
            <div class="mb-10">

              <%# Month label %>
              <h3 class="mb-5 text-xs font-medium uppercase tracking-[0.18em] text-neutral-400 dark:text-neutral-500">
                <%= I18n.l(Date.new(year, month_num, 1), format: "%B") %>
              </h3>

              <%# Post list %>
              <div class="divide-y divide-neutral-100 dark:divide-neutral-800/60">
                <% posts.each do |post| %>
                  <article class="py-6 first:pt-0">
                    <div class="flex items-start justify-between gap-4">
                      <div class="min-w-0 flex-1">
                        <h4 class="text-base font-semibold leading-snug tracking-tight text-neutral-950 dark:text-neutral-50">
                          <%= link_to post.localized_title, post_path(post),
                                class: "hover:text-blue-700 dark:hover:text-blue-300 transition-colors" %>
                        </h4>
                        <p class="mt-2 text-sm leading-relaxed text-neutral-500 dark:text-neutral-400">
                          <%= post.localized_excerpt %>
                        </p>
                        <div class="mt-3 flex items-center gap-3">
                          <time class="text-xs text-neutral-400 dark:text-neutral-500">
                            <%= display_date(post.published_at) %>
                          </time>
                          <span class="text-neutral-300 dark:text-neutral-700">·</span>
                          <%= link_to "Read →", post_path(post),
                                class: "text-xs font-medium text-blue-700 hover:underline dark:text-blue-400" %>
                        </div>
                      </div>
                    </div>
                  </article>
                <% end %>
              </div>

            </div>
          <% end %>
        </section>
      <% end %>
    <% else %>
      <p class="text-neutral-500 dark:text-neutral-400"><%= t("posts.index.empty") %></p>
    <% end %>

  </div>

  <%# ─── Sidebar ─── %>
  <aside class="hidden lg:block">
    <div class="sticky top-20 space-y-10">

      <%# Recent posts %>
      <section>
        <h2 class="mb-4 text-xs font-semibold uppercase tracking-[0.18em] text-neutral-400 dark:text-neutral-500">
          <%= t("posts.index.sidebar.recent") %>
        </h2>
        <ul class="space-y-3">
          <% @recent_posts.each do |post| %>
            <li class="border-l-2 border-neutral-200 pl-3 dark:border-neutral-700">
              <%= link_to post.localized_title, post_path(post),
                    class: "line-clamp-2 text-sm leading-snug text-neutral-700 hover:text-blue-700 dark:text-neutral-300 dark:hover:text-blue-300 transition-colors" %>
              <p class="mt-0.5 text-xs text-neutral-400 dark:text-neutral-500">
                <%= display_date(post.published_at) %>
              </p>
            </li>
          <% end %>
        </ul>
      </section>

      <%# Archive by month %>
      <section>
        <h2 class="mb-4 text-xs font-semibold uppercase tracking-[0.18em] text-neutral-400 dark:text-neutral-500">
          <%= t("posts.index.sidebar.archive") %>
        </h2>
        <ul class="space-y-1.5">
          <% @archive_counts.each do |ym, count| %>
            <% year_m, month_m = ym.split("-").map(&:to_i) %>
            <li class="flex items-center justify-between">
              <span class="text-sm text-neutral-600 dark:text-neutral-400">
                <%= I18n.l(Date.new(year_m, month_m, 1), format: "%B %Y") %>
              </span>
              <span class="rounded-full bg-neutral-100 px-2 py-0.5 text-xs font-medium text-neutral-500 dark:bg-neutral-800 dark:text-neutral-400">
                <%= count %>
              </span>
            </li>
          <% end %>
        </ul>
      </section>

    </div>
  </aside>

</div>
