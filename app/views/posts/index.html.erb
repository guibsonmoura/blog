<% page_title "Guibson Moura Blog" %>

<div class="grid grid-cols-1 gap-12 lg:grid-cols-[1fr_260px]">

  <%# ─── Main content ─── %>
  <div>
    <%# Hero %>
    <div class="mb-12 text-center">
      <h1 class="text-2xl font-semibold text-neutral-950 dark:text-neutral-50">Guibson Moura Blog</h1>
      <p class="mt-2 text-sm text-neutral-500 dark:text-neutral-400">
        Thoughts about software, architecture and technology
      </p>
    </div>

    <%# Archive grouped by year → month %>
    <% if @archive.any? %>
      <% @archive.sort.reverse_each do |year, months| %>
        <section class="mb-10">
          <h2 class="mb-4 text-lg font-semibold text-neutral-950 dark:text-neutral-50"><%= year %></h2>

          <% months.sort.reverse_each do |month_num, posts| %>
            <div class="mb-6">
              <h3 class="mb-3 text-xs font-semibold uppercase tracking-widest text-neutral-400 dark:text-neutral-500">
                <%= I18n.l(Date.new(year, month_num, 1), format: "%B") %>
              </h3>

              <div class="space-y-5">
                <% posts.each do |post| %>
                  <article>
                    <p class="text-xs text-neutral-400 dark:text-neutral-500">
                      <%= display_date(post.published_at) %>
                    </p>
                    <h4 class="mt-0.5 font-medium text-neutral-950 dark:text-neutral-50">
                      <%= link_to post.localized_title, post_path(post),
                            class: "hover:text-blue-700 dark:hover:text-blue-300" %>
                    </h4>
                    <p class="mt-1 text-sm leading-relaxed text-neutral-600 dark:text-neutral-400">
                      <%= post.localized_excerpt %>
                    </p>
                    <%= link_to "Read more →", post_path(post),
                          class: "mt-1 inline-block text-xs text-blue-700 hover:underline dark:text-blue-400" %>
                  </article>
                <% end %>
              </div>
            </div>
          <% end %>
        </section>
      <% end %>
    <% else %>
      <p class="text-neutral-500 dark:text-neutral-400"><%= t("posts.index.empty") %></p>
    <% end %>
  </div>

  <%# ─── Sidebar (desktop only) ─── %>
  <aside class="hidden lg:block">
    <div class="sticky top-20 space-y-8">

      <%# Recent posts %>
      <section>
        <h2 class="mb-3 text-xs font-semibold uppercase tracking-widest text-neutral-500 dark:text-neutral-400">
          Recent posts
        </h2>
        <ul class="space-y-2">
          <% @recent_posts.each do |post| %>
            <li>
              <%= link_to post.localized_title, post_path(post),
                    class: "line-clamp-2 text-sm text-neutral-700 hover:text-blue-700 dark:text-neutral-300 dark:hover:text-blue-300" %>
            </li>
          <% end %>
        </ul>
      </section>

      <%# Archive by month %>
      <section>
        <h2 class="mb-3 text-xs font-semibold uppercase tracking-widest text-neutral-500 dark:text-neutral-400">
          Archive
        </h2>
        <ul class="space-y-1">
          <% @archive_counts.each do |ym, count| %>
            <% year_m, month_m = ym.split("-").map(&:to_i) %>
            <li class="flex items-center justify-between text-sm">
              <span class="text-neutral-600 dark:text-neutral-400">
                <%= I18n.l(Date.new(year_m, month_m, 1), format: "%B %Y") %>
              </span>
              <span class="text-xs text-neutral-400 dark:text-neutral-500"><%= count %></span>
            </li>
          <% end %>
        </ul>
      </section>

    </div>
  </aside>

</div>
