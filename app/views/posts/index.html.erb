<% page_title t("posts.index.title") %>

<section class="max-w-3xl">
  <p class="text-sm uppercase tracking-[0.18em] text-neutral-500 dark:text-neutral-400"><%= t("posts.index.section_label") %></p>
  <h1 class="mt-3 text-4xl font-semibold leading-tight text-neutral-950 dark:text-neutral-50"><%= t("posts.index.title") %></h1>
</section>

<section class="mt-12">
  <% if @posts.any? %>
    <%= render @posts %>
  <% else %>
    <p class="text-neutral-600 dark:text-neutral-300"><%= t("posts.index.empty") %></p>
  <% end %>
</section>

<% if @total_pages > 1 %>
  <nav class="mt-10 flex items-center justify-between border-t border-neutral-200 pt-6 text-sm dark:border-neutral-800">
    <% if @page > 1 %>
      <%= link_to t("posts.index.pagination.previous"), posts_path(page: @page - 1), class: "text-neutral-700 hover:text-blue-700 dark:text-neutral-300 dark:hover:text-blue-300" %>
    <% else %>
      <span></span>
    <% end %>

    <span class="text-neutral-500 dark:text-neutral-400"><%= t("posts.index.pagination.page_of", page: @page, total: @total_pages) %></span>

    <% if @page < @total_pages %>
      <%= link_to t("posts.index.pagination.next"), posts_path(page: @page + 1), class: "text-neutral-700 hover:text-blue-700 dark:text-neutral-300 dark:hover:text-blue-300" %>
    <% else %>
      <span></span>
    <% end %>
  </nav>
<% end %>
