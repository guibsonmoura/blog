<section id="comments" class="border-t border-neutral-200 pt-12 dark:border-neutral-800">
  <h2 class="text-sm font-medium uppercase tracking-[0.18em] text-neutral-500 dark:text-neutral-400">
    <%= t("posts.show.comments_section") %>
  </h2>

  <% threads = post.comments.top_level.includes(:reader, :comment_likes, replies: [ :reader, :comment_likes ]).order(:created_at) %>

  <div class="flex items-baseline justify-between gap-3">
    <h2 class="text-sm font-medium uppercase tracking-[0.18em] text-neutral-500 dark:text-neutral-400">
      <%= t("posts.show.comments_section") %>
    </h2>
    <% if threads.size.positive? %>
      <span class="inline-flex items-center rounded-full bg-neutral-100 px-2.5 py-0.5 text-xs font-medium tabular-nums text-neutral-600 dark:bg-neutral-800 dark:text-neutral-300">
        <%= threads.size %>
      </span>
    <% end %>
  </div>

  <% if threads.any? %>
    <div class="mt-4 divide-y divide-neutral-100 dark:divide-neutral-800/70">
      <% threads.each do |comment| %>
        <div class="py-1">
          <%= render "comment", comment: comment, allow_reply: true %>

          <% if comment.replies.any? %>
            <div class="ml-5 border-l-2 border-neutral-100 pl-4 dark:border-neutral-800">
              <% comment.replies.sort_by(&:created_at).each do |reply| %>
                <%= render "comment", comment: reply, allow_reply: false %>
              <% end %>
            </div>
          <% end %>
        </div>
      <% end %>
    </div>
  <% else %>
    <div class="mt-6 rounded-xl border border-dashed border-neutral-200 px-6 py-10 text-center dark:border-neutral-800">
      <p class="text-sm text-neutral-500 dark:text-neutral-400"><%= t("posts.show.no_comments") %></p>
    </div>
  <% end %>

  <div id="comment-form" class="mt-10 border-t border-neutral-200 pt-10 dark:border-neutral-800">
    <% if reader_signed_in? %>
      <div class="mb-4 flex items-center gap-3">
        <% if current_reader.avatar_url.present? %>
          <%= image_tag current_reader.avatar_url, alt: "", loading: "lazy", referrerpolicy: "no-referrer",
                        class: "h-8 w-8 shrink-0 rounded-full object-cover ring-1 ring-neutral-200 dark:ring-neutral-800" %>
        <% else %>
          <span class="flex h-8 w-8 shrink-0 items-center justify-center rounded-full bg-neutral-100 text-sm font-semibold text-neutral-500 ring-1 ring-neutral-200 dark:bg-neutral-800 dark:text-neutral-400 dark:ring-neutral-700">
            <%= current_reader.name.to_s.strip.first&.upcase.presence || "?" %>
          </span>
        <% end %>
        <p class="flex min-w-0 flex-wrap items-center gap-x-2 text-sm text-neutral-500 dark:text-neutral-400">
          <span class="truncate"><%= t("auth.signed_in_as", name: current_reader.name) %></span>
          <span aria-hidden="true" class="text-neutral-300 dark:text-neutral-600">·</span>
          <%= button_to t("auth.sign_out"), reader_logout_path, method: :delete,
                        class: "font-medium text-blue-700 underline-offset-2 hover:underline dark:text-blue-300" %>
        </p>
      </div>

      <%= form_with url: post_comments_path(post), class: "space-y-3" do |f| %>
        <%= f.label :body, t("comments.form.body_label"), class: "sr-only" %>
        <%= f.text_area :body,
                        required: true,
                        rows: 4,
                        placeholder: t("comments.form.body_placeholder"),
                        class: "w-full rounded-xl border border-neutral-300 bg-white px-4 py-3 text-sm text-neutral-950 shadow-sm transition focus:border-blue-600 focus:outline-none focus:ring-2 focus:ring-blue-600/20 dark:border-neutral-700 dark:bg-neutral-900 dark:text-neutral-50" %>
        <div class="flex justify-end">
          <%= f.submit t("comments.form.submit"),
                       class: "rounded-full bg-neutral-950 px-5 py-2.5 text-sm font-medium text-white transition-colors hover:bg-blue-700 dark:bg-neutral-100 dark:text-neutral-950 dark:hover:bg-blue-200" %>
        </div>
      <% end %>
    <% else %>
      <p class="text-sm font-medium text-neutral-700 dark:text-neutral-300"><%= t("auth.sign_in_to_comment") %></p>
      <div class="mt-4 grid grid-cols-1 gap-3 sm:grid-cols-2">
        <%# button_to issues a CSRF-protected POST — required by omniauth-rails_csrf_protection. %>
        <%# data-turbo=false lets the browser follow the cross-origin redirect to the provider. %>
        <%# Only configured providers appear (plus a local Dev sign-in in development). %>
        <% reader_sign_in_buttons.each do |button| %>
          <% provider = button[:path].split("/").last %>
          <%= button_to button[:path],
                        data: { turbo: false },
                        class: "group inline-flex items-center justify-center gap-2.5 rounded-xl border border-neutral-200 bg-white px-4 py-2.5 text-sm font-medium text-neutral-800 shadow-sm transition hover:border-neutral-300 hover:shadow dark:border-neutral-700 dark:bg-neutral-900 dark:text-neutral-100 dark:hover:border-neutral-600" do %>
            <span class="h-4 w-4 shrink-0"><%= render "posts/provider_icon", provider: provider %></span>
            <%= t(button[:label_key]) %>
          <% end %>
        <% end %>
      </div>
    <% end %>
  </div>
</section>
