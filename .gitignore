# Ignore Rails runtime artifacts
/tmp/*
!/tmp/.keep
/log/*
!/log/.keep
/storage/*
!/storage/.keep

# Bundler
/.bundle
/vendor/bundle

# Credentials
/config/credentials/*.key
/config/master.key

# Local OAuth secrets (never commit real client ids/secrets)
/.env.oauth

# Node
/node_modules

# OS
.DS_Store
