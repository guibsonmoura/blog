# Local OAuth credentials for public reader sign-in (development only).
#
# Copy this file to `.env.oauth` (which is git-ignored) and fill in real values
# from each provider's developer console. The dev server loads it on boot — see
# README / the restart command. Leave a provider blank to keep it disabled
# (its button will 401 until configured).
#
# Local callback host for this worktree's preview container is http://localhost:3002

# --- Google (Google Cloud Console → APIs & Services → Credentials → OAuth client ID, type "Web application") ---
# Authorized redirect URI: http://localhost:3002/auth/google_oauth2/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# --- Microsoft (Entra ID → App registrations) ---
# Redirect URI (Web): http://localhost:3002/auth/entra_id/callback
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=
MICROSOFT_TENANT_ID=common

# --- Facebook (Meta for Developers → your app → Facebook Login) ---
# Valid OAuth redirect URI: http://localhost:3002/auth/facebook/callback
FACEBOOK_CLIENT_ID=
FACEBOOK_CLIENT_SECRET=

# --- X / Twitter (developer.x.com → Project → App → User authentication settings, OAuth 2.0) ---
# Type of App: Web App (confidential). Use the OAuth 2.0 Client ID and Secret.
# Callback URI: http://localhost:3002/auth/twitter/callback
TWITTER_CLIENT_ID=
TWITTER_CLIENT_SECRET=
